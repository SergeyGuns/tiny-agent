{
  "name": "tiny-agent",
  "version": "1.0.0",
  "type": "module",
  "license": "ISC",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/agent.js",
    "tui": "tsc && node dist/agent.js",
    "clean": "node -e \"const fs = require('fs'); ['dist', 'session.log', 'bench-report.json'].forEach(p => fs.existsSync(p) && fs.rmSync(p, {recursive: true}))\"",
    "test": "npx tsc ; node --test --test-force-exit dist/test/lib.test.js",
    "test:tui": "node --test --test-timeout=120000 --test-force-exit dist/test/tui.test.js",
    "test:all": "npx tsc ; node --test --test-timeout=120000 --test-force-exit dist/test/*.test.js",
    "bench": "npx tsc ; node dist/bench/runner.js",
    "bench:unit": "npm test",
    "bench:category": "npx tsc ; node dist/bench/runner.js --category",
    "bench:task": "npx tsc ; node dist/bench/runner.js --task"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "playwright": "^1.60.0"
  }
}
