# .env.example
# ==========================================
# Конфигурация LLM API Endpoint для RLM
# Пожалуйста, настройте эти переменные, чтобы указать на ваш локальный инстанс.
# Используется в rlm_wrapper.ts и lib.ts/queryLLM

# Базовый URL вашего локального сервера LLM (OpenAI-совместимый)
# Пример: http://localhost:1234/v1 или http://192.168.0.156:1234/v1
LM_STUDIO_URL="http://192.168.0.156:1234"

# Имя модели, используемой на сервере (должно соответствовать доступной модели)
# Пример: google/gemma-4-e4b
LM_STUDIO_MODEL="google/gemma-4-e4b"

# Если вы используете ключи API, добавьте их сюда
# OPENAI_API_KEY="sk-..."

# Максимальное количество шагов агента
# MAX_STEP=50
